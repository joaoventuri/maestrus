# Access key for your self-hosted Maestrus. It is the ONLY credential — anyone
# who has it gets in. Generate a strong one:  openssl rand -hex 32
SELFHOST_SECRET=change-me-to-a-real-strong-secret

# Name shown in the apps
HOST_NAME=My Maestrus

# Public port (the only one exposed). Default 8090.
MAESTRUS_PORT=8090
