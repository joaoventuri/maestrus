[Unit]
Description=Maestrus Relay (WebSocket)
After=network.target

[Service]
Type=simple
User=maestrus
WorkingDirectory=/home/maestrus/maestrus-relay
# RELAY_SECRET (e PORT opcional) ficam aqui, FORA do git:
EnvironmentFile=/home/maestrus/maestrus-relay/.env
ExecStart=/usr/bin/node bin/relay.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
